{
    "dataRoles": [
        {
            "displayName": "Label",
            "name": "label",
            "kind": "Grouping"
        },
        {
            "displayName": "Value",
            "name": "value",
            "kind": "Measure"
        },
        {
            "displayName": "Target",
            "name": "target",
            "kind": "Measure"
        },
        {
            "displayName": "Comparative",
            "name": "comparative",
            "kind": "Measure"
        },
        {
            "displayName": "Poor Threshold",
            "name": "poorThreshold",
            "kind": "Measure"
        },
        {
            "displayName": "Satisfactory Threshold",
            "name": "satisfThreshold",
            "kind": "Measure"
        },
        {
            "displayName": "Maximum",
            "name": "maximum",
            "kind": "Measure"
        }
    ],
    "objects": {
        "chartSettings": {
            "properties": {
                "rowHeight": {
                    "type": {
                        "numeric": true
                    }
                },
                "bgBarHeight": {
                    "type": {
                        "numeric": true
                    }
                },
                "perfBarHeight": {
                    "type": {
                        "numeric": true
                    }
                },
                "showComparative": {
                    "type": {
                        "bool": true
                    }
                },
                "showSummary": {
                    "type": {
                        "bool": true
                    }
                },
                "fontFamily": {
                    "type": {
                        "text": true
                    }
                }
            }
        },
        "colorSettings": {
            "properties": {
                "redZoneColor": {
                    "type": {
                        "fill": {
                            "solid": {
                                "color": true
                            }
                        }
                    }
                },
                "amberZoneColor": {
                    "type": {
                        "fill": {
                            "solid": {
                                "color": true
                            }
                        }
                    }
                },
                "greenZoneColor": {
                    "type": {
                        "fill": {
                            "solid": {
                                "color": true
                            }
                        }
                    }
                },
                "targetColor": {
                    "type": {
                        "fill": {
                            "solid": {
                                "color": true
                            }
                        }
                    }
                },
                "comparativeColor": {
                    "type": {
                        "fill": {
                            "solid": {
                                "color": true
                            }
                        }
                    }
                }
            }
        }
    },
    "dataViewMappings": [
        {
            "conditions": [
                {
                    "label": {
                        "max": 1
                    },
                    "value": {
                        "max": 1
                    },
                    "target": {
                        "max": 1
                    },
                    "comparative": {
                        "max": 1
                    },
                    "poorThreshold": {
                        "max": 1
                    },
                    "satisfThreshold": {
                        "max": 1
                    },
                    "maximum": {
                        "max": 1
                    }
                }
            ],
            "categorical": {
                "categories": {
                    "for": {
                        "in": "label"
                    },
                    "dataReductionAlgorithm": {
                        "top": {
                            "count": 20
                        }
                    }
                },
                "values": {
                    "select": [
                        {
                            "bind": {
                                "to": "value"
                            }
                        },
                        {
                            "bind": {
                                "to": "target"
                            }
                        },
                        {
                            "bind": {
                                "to": "comparative"
                            }
                        },
                        {
                            "bind": {
                                "to": "poorThreshold"
                            }
                        },
                        {
                            "bind": {
                                "to": "satisfThreshold"
                            }
                        },
                        {
                            "bind": {
                                "to": "maximum"
                            }
                        }
                    ]
                }
            }
        }
    ],
    "tooltips": {
        "supportedTypes": {
            "default": true,
            "canvas": true
        }
    },
    "supportsLandingPage": true,
    "supportsEmptyDataView": true,
    "privileges": []
}