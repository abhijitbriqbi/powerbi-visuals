{
    "dataRoles": [
        {
            "displayName": "Category",
            "name": "category",
            "kind": "Grouping"
        },
        {
            "displayName": "X Value",
            "name": "xAxis",
            "kind": "Measure"
        },
        {
            "displayName": "Y Value",
            "name": "yAxis",
            "kind": "Measure"
        },
        {
            "displayName": "Bubble Size",
            "name": "bubbleSize",
            "kind": "Measure"
        },
        {
            "displayName": "Colour Group",
            "name": "colorGroup",
            "kind": "Grouping"
        },
        {
            "displayName": "Tooltip Fields",
            "name": "tooltipValues",
            "kind": "Measure"
        }
    ],
    "dataViewMappings": [
        {
            "conditions": [
                {
                    "category": {
                        "max": 1
                    },
                    "xAxis": {
                        "max": 1
                    },
                    "yAxis": {
                        "max": 1
                    },
                    "bubbleSize": {
                        "max": 1
                    },
                    "colorGroup": {
                        "max": 1
                    },
                    "tooltipValues": {
                        "max": 3
                    }
                }
            ],
            "categorical": {
                "categories": {
                    "select": [
                        {
                            "bind": {
                                "to": "category"
                            }
                        },
                        {
                            "bind": {
                                "to": "colorGroup"
                            }
                        }
                    ],
                    "dataReductionAlgorithm": {
                        "top": {
                            "count": 1000
                        }
                    }
                },
                "values": {
                    "select": [
                        {
                            "bind": {
                                "to": "xAxis"
                            }
                        },
                        {
                            "bind": {
                                "to": "yAxis"
                            }
                        },
                        {
                            "bind": {
                                "to": "bubbleSize"
                            }
                        },
                        {
                            "bind": {
                                "to": "tooltipValues"
                            }
                        }
                    ]
                }
            }
        }
    ],
    "drilldown": {
        "roles": [
            "category"
        ]
    },
