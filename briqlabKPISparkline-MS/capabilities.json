{
    "dataRoles": [
        {
            "displayName": "KPI Value",
            "name": "kpiValue",
            "kind": "Measure"
        },
        {
            "displayName": "Trend Values",
            "name": "sparklineValues",
            "kind": "Measure"
        },
        {
            "displayName": "Trend Date",
            "name": "sparklineDate",
            "kind": "Grouping"
        },
        {
            "displayName": "Target",
            "name": "targetValue",
            "kind": "Measure"
        },
        {
            "displayName": "Comparison",
            "name": "comparisonValue",
            "kind": "Measure"
        }
    ],
    "dataViewMappings": [
        {
            "conditions": [
                {
                    "kpiValue": {
                        "max": 1
                    },
                    "sparklineValues": {
                        "max": 1
                    },
                    "sparklineDate": {
                        "max": 1
                    },
                    "targetValue": {
                        "max": 1
                    },
                    "comparisonValue": {
                        "max": 1
                    }
                }
            ],
            "categorical": {
                "categories": {
                    "for": {
                        "in": "sparklineDate"
                    },
                    "dataReductionAlgorithm": {
                        "top": {
                            "count": 500
                        }
                    }
                },
                "values": {
                    "select": [
                        {
                            "bind": {
                                "to": "kpiValue"
                            }
                        },
                        {
                            "bind": {
                                "to": "sparklineValues"
                            }
                        },
                        {
                            "bind": {
                                "to": "targetValue"
                            }
                        },
                        {
                            "bind": {
                                "to": "comparisonValue"
                            }
                        }
                    ]
                }
            }
        }
    ],
    "objects": {
        "valueSettings": {
            "properties": {
                "currencyPrefix": {
                    "type": {
                        "text": true
                    }
                },
                "valueSize": {
                    "type": {
                        "numeric": true
                    }
                },
                "showTrend": {
                    "type": {
                        "bool": true
                    }
                },
                "countUpAnimation": {
                    "type": {
                        "bool": true
                    }
                },
                "fontFamily": {
                    "type": {
                        "text": true
                    }
                }
            }
        },
        "targetSettings": {
            "properties": {
                "showTargetBar": {
                    "type": {
                        "bool": true
                    }
                },
                "targetLabel": {
                    "type": {
                        "text": true
                    }
                },
                "aboveTargetColor": {
                    "type": {
                        "fill": {
                            "solid": {
                                "color": true
                            }
                        }
                    }
                },
                "belowTargetColor": {
                    "type": {
                        "fill": {
                            "solid": {
                                "color": true
                            }
                        }
                    }
                }
            }
        },
        "sparklineSettings": {
            "properties": {
                "showSparkline": {
                    "type": {
                        "bool": true
                    }
                },
                "sparklineType": {
                    "type": {
                        "text": true
                    }
                },
                "sparklineHeight": {
                    "type": {
                        "numeric": true
                    }
                },
                "sparklineColor": {
                    "type": {
                        "text": true
                    }
                },
                "manualSparklineColor": {
                    "type": {
                        "fill": {
                            "solid": {
                                "color": true
                            }
                        }
                    }
                }
            }
        },
        "cardStyle": {
            "properties": {
                "backgroundColor": {
                    "type": {
                        "fill": {
                            "solid": {
                                "color": true
                            }
                        }
                    }
                },
                "accentColor": {
                    "type": {
                        "text": true
                    }
                },
                "manualAccentColor": {
                    "type": {
                        "fill": {
                            "solid": {
                                "color": true
                            }
                        }
                    }
                },
                "borderRadius": {
                    "type": {
                        "numeric": true
                    }
                },
                "showShadow": {
                    "type": {
                        "bool": true
                    }
                }
            }
        }
    },
    "tooltips": {
        "supportedTypes": {
            "default": true,
            "canvas": true
        }
    },
    "supportsLandingPage": true,
    "supportsEmptyDataView": true,
    "privileges": []
}