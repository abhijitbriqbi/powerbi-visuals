{
    "dataRoles": [
        {
            "displayName": "Category",
            "name": "category",
            "kind": "Grouping",
            "description": "Item labels — company names, products, regions, etc."
        },
        {
            "displayName": "Value",
            "name": "value",
            "kind": "Measure",
            "description": "Primary numeric value to display"
        },
        {
            "displayName": "Change / Delta",
            "name": "changeValue",
            "kind": "Measure",
            "description": "Change value for directional arrow indicator (positive = up arrow, negative = down arrow)"
        }
    ],
    "objects": {
        "scrollSettings": {
            "properties": {
                "speed": {
                    "type": {
                        "numeric": true
                    }
                },
                "direction": {
                    "type": {
                        "text": true
                    }
                },
                "pauseOnHover": {
                    "type": {
                        "bool": true
                    }
                },
                "gap": {
                    "type": {
                        "numeric": true
                    }
                }
            }
        },
        "appearanceSettings": {
            "properties": {
                "backgroundColor": {
                    "type": {
                        "fill": {
                            "solid": {
                                "color": true
                            }
                        }
                    }
                },
                "transparentBackground": {
                    "type": {
                        "bool": true
                    }
                },
                "textColor": {
                    "type": {
                        "fill": {
                            "solid": {
                                "color": true
                            }
                        }
                    }
                },
                "fontSize": {
                    "type": {
                        "numeric": true
                    }
                },
                "fontFamily": {
                    "type": {
                        "text": true
                    }
                },
                "padding": {
                    "type": {
                        "numeric": true
                    }
                }
            }
        },
        "indicatorSettings": {
            "properties": {
                "showArrows": {
                    "type": {
                        "bool": true
                    }
                },
                "positiveColor": {
                    "type": {
                        "fill": {
                            "solid": {
                                "color": true
                            }
                        }
                    }
                },
                "negativeColor": {
                    "type": {
                        "fill": {
                            "solid": {
                                "color": true
                            }
                        }
                    }
                },
                "invertColors": {
                    "type": {
                        "bool": true
                    }
                },
                "showValue": {
                    "type": {
                        "bool": true
                    }
                },
                "showChange": {
                    "type": {
                        "bool": true
                    }
                }
            }
        },
        "numberSettings": {
            "properties": {
                "decimalPlaces": {
                    "type": {
                        "numeric": true
                    }
                },
                "useKM": {
                    "type": {
                        "bool": true
                    }
                },
                "prefix": {
                    "type": {
                        "text": true
                    }
                },
                "suffix": {
                    "type": {
                        "text": true
                    }
                },
                "changePrefix": {
                    "type": {
                        "text": true
                    }
                },
                "changeSuffix": {
                    "type": {
                        "text": true
                    }
                }
            }
        },
        "separatorSettings": {
            "properties": {
                "separatorChar": {
                    "type": {
                        "text": true
                    }
                },
                "separatorColor": {
                    "type": {
                        "fill": {
                            "solid": {
                                "color": true
                            }
                        }
                    }
                }
            }
        },
        "customTextSettings": {
            "properties": {
                "useCustomText": {
                    "type": {
                        "bool": true
                    }
                },
                "customText": {
                    "type": {
                        "text": true
                    }
                }
            }
        }
    },
    "dataViewMappings": [
        {
            "conditions": [
                {
                    "category": {
                        "max": 1
                    },
                    "value": {
                        "max": 1
                    },
                    "changeValue": {
                        "max": 1
                    }
                }
            ],
            "categorical": {
                "categories": {
                    "for": {
                        "in": "category"
                    },
                    "dataReductionAlgorithm": {
                        "top": {
                            "count": 1000
                        }
                    }
                },
                "values": {
                    "select": [
                        {
                            "bind": {
                                "to": "value"
                            }
                        },
                        {
                            "bind": {
                                "to": "changeValue"
                            }
                        }
                    ]
                }
            }
        }
    ],
    "tooltips": {
        "supportedTypes": {
            "default": true,
            "canvas": true
        }
    },
    "supportsLandingPage": true,
    "supportsEmptyDataView": true,
    "privileges": []
}