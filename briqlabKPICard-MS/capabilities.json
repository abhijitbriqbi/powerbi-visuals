{
    "dataRoles": [
        {
            "displayName": "KPI Value",
            "name": "measure",
            "kind": "Measure"
        },
        {
            "displayName": "Label",
            "name": "label",
            "kind": "Grouping"
        },
        {
            "displayName": "Comparison Value",
            "name": "comparisonMeasure",
            "kind": "Measure"
        }
    ],
    "objects": {
        "displaySettings": {
            "properties": {
                "valueFontSize": {
                    "type": {
                        "numeric": true
                    }
                },
                "labelFontSize": {
                    "type": {
                        "numeric": true
                    }
                },
                "primaryColor": {
                    "type": {
                        "fill": {
                            "solid": {
                                "color": true
                            }
                        }
                    }
                },
                "backgroundColor": {
                    "type": {
                        "fill": {
                            "solid": {
                                "color": true
                            }
                        }
                    }
                },
                "showBorder": {
                    "type": {
                        "bool": true
                    }
                },
                "borderColor": {
                    "type": {
                        "fill": {
                            "solid": {
                                "color": true
                            }
                        }
                    }
                },
                "borderRadius": {
                    "type": {
                        "numeric": true
                    }
                },
                "fontFamily": {
                    "type": {
                        "text": true
                    }
                }
            }
        }
    },
    "dataViewMappings": [
        {
            "conditions": [
                {
                    "measure": {
                        "max": 1
                    },
                    "label": {
                        "max": 1
                    },
                    "comparisonMeasure": {
                        "max": 1
                    }
                }
            ],
            "categorical": {
                "categories": {
                    "for": {
                        "in": "label"
                    },
                    "dataReductionAlgorithm": {
                        "top": {
                            "count": 1
                        }
                    }
                },
                "values": {
                    "select": [
                        {
                            "bind": {
                                "to": "measure"
                            }
                        },
                        {
                            "bind": {
                                "to": "comparisonMeasure"
                            }
                        }
                    ]
                }
            }
        }
    ],
    "tooltips": {
        "supportedTypes": {
            "default": true,
            "canvas": true
        }
    },
    "supportsLandingPage": true,
    "supportsEmptyDataView": true,
    "privileges": []
}