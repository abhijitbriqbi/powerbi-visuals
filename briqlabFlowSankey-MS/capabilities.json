{
    "dataRoles": [
        {
            "displayName": "Source",
            "name": "source",
            "kind": "Grouping"
        },
        {
            "displayName": "Destination",
            "name": "destination",
            "kind": "Grouping"
        },
        {
            "displayName": "Value",
            "name": "value",
            "kind": "Measure"
        },
        {
            "displayName": "Tooltip Extra",
            "name": "tooltip",
            "kind": "Measure"
        }
    ],
    "objects": {
        "layoutSettings": {
            "properties": {
                "nodeWidth": {
                    "type": {
                        "numeric": true
                    }
                },
                "nodeGap": {
                    "type": {
                        "numeric": true
                    }
                },
                "flowOpacity": {
                    "type": {
                        "numeric": true
                    }
                },
                "showFlowLabels": {
                    "type": {
                        "bool": true
                    }
                },
                "minLabelPct": {
                    "type": {
                        "numeric": true
                    }
                },
                "fontFamily": {
                    "type": {
                        "text": true
                    }
                }
            }
        }
    },
    "dataViewMappings": [
        {
            "conditions": [
                {
                    "source": {
                        "max": 1
                    },
                    "destination": {
                        "max": 1
                    },
                    "value": {
                        "max": 1
                    },
                    "tooltip": {
                        "max": 1
                    }
                }
            ],
            "categorical": {
                "categories": {
                    "select": [
                        {
                            "bind": {
                                "to": "source"
                            }
                        },
                        {
                            "bind": {
                                "to": "destination"
                            }
                        }
                    ],
                    "dataReductionAlgorithm": {
                        "top": {
                            "count": 1000
                        }
                    }
                },
                "values": {
                    "select": [
                        {
                            "bind": {
                                "to": "value"
                            }
                        },
                        {
                            "bind": {
                                "to": "tooltip"
                            }
                        }
                    ]
                }
            }
        }
    ],
    "tooltips": {
        "supportedTypes": {
            "default": true,
            "canvas": true
        }
    },
    "supportsLandingPage": true,
    "supportsEmptyDataView": true,
    "privileges": []
}