{
    "dataRoles": [
        {
            "displayName": "Category",
            "name": "category",
            "kind": "Grouping"
        },
        {
            "displayName": "Values",
            "name": "measure",
            "kind": "Measure"
        },
        {
            "displayName": "Comparison Values",
            "name": "comparisonMeasure",
            "kind": "Measure"
        }
    ],
    "objects": {
        "chartSettings": {
            "properties": {
                "orientation": {
                    "type": {
                        "text": true
                    }
                },
                "barMode": {
                    "type": {
                        "text": true
                    }
                },
                "barColor": {
                    "type": {
                        "fill": {
                            "solid": {
                                "color": true
                            }
                        }
                    }
                },
                "comparisonColor": {
                    "type": {
                        "fill": {
                            "solid": {
                                "color": true
                            }
                        }
                    }
                },
                "series3Color": {
                    "type": {
                        "fill": {
                            "solid": {
                                "color": true
                            }
                        }
                    }
                },
                "cornerRadius": {
                    "type": {
                        "numeric": true
                    }
                },
                "barPadding": {
                    "type": {
                        "numeric": true
                    }
                },
                "showBackground": {
                    "type": {
                        "bool": true
                    }
                },
                "backgroundColor": {
                    "type": {
                        "fill": {
                            "solid": {
                                "color": true
                            }
                        }
                    }
                }
            }
        },
        "labelSettings": {
            "properties": {
                "showLabels": {
                    "type": {
                        "bool": true
                    }
                },
                "labelFontSize": {
                    "type": {
                        "numeric": true
                    }
                },
                "labelFormat": {
                    "type": {
                        "text": true
                    }
                },
                "labelColor": {
                    "type": {
                        "fill": {
                            "solid": {
                                "color": true
                            }
                        }
                    }
                },
                "boldLabels": {
                    "type": {
                        "bool": true
                    }
                }
            }
        },
        "fontSettings": {
            "properties": {
                "fontFamily": {
                    "type": {
                        "text": true
                    }
                },
                "boldAxis": {
                    "type": {
                        "bool": true
                    }
                },
                "italicAxis": {
                    "type": {
                        "bool": true
                    }
                }
            }
        },
        "numberFormat": {
            "properties": {
                "decimalPlaces": {
                    "type": {
                        "numeric": true
                    }
                },
                "useKM": {
                    "type": {
                        "bool": true
                    }
                },
                "prefix": {
                    "type": {
                        "text": true
                    }
                },
                "suffix": {
                    "type": {
                        "text": true
                    }
                }
            }
        },
        "axisSettings": {
            "properties": {
                "xFontSize": {
                    "type": {
                        "numeric": true
                    }
                },
                "yFontSize": {
                    "type": {
                        "numeric": true
                    }
                },
                "xTitle": {
                    "type": {
                        "text": true
                    }
                },
                "yTitle": {
                    "type": {
                        "text": true
                    }
                },
                "showGridlines": {
                    "type": {
                        "bool": true
                    }
                },
                "gridlineColor": {
                    "type": {
                        "fill": {
                            "solid": {
                                "color": true
                            }
                        }
                    }
                },
                "showZeroLine": {
                    "type": {
                        "bool": true
                    }
                }
            }
        }
    },
    "dataViewMappings": [
        {
            "conditions": [
                {
                    "category": {
                        "max": 1
                    },
                    "measure": {
                        "max": 1
                    },
                    "comparisonMeasure": {
                        "max": 1
                    }
                }
            ],
            "categorical": {
                "categories": {
                    "for": {
                        "in": "category"
                    },
                    "dataReductionAlgorithm": {
                        "top": {
                            "count": 500
                        }
                    }
                },
                "values": {
                    "select": [
                        {
                            "bind": {
                                "to": "measure"
                            }
                        },
                        {
                            "bind": {
                                "to": "comparisonMeasure"
                            }
                        }
                    ]
                }
            }
        }
    ],
    "tooltips": {
        "supportedTypes": {
            "default": true,
            "canvas": true
        }
    },
    "supportsLandingPage": true,
    "supportsEmptyDataView": true,
    "privileges": []
}