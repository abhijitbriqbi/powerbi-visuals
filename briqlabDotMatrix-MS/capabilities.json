{
    "dataRoles": [
        {
            "displayName": "Total",
            "name": "total",
            "kind": "Measure"
        },
        {
            "displayName": "Achieved",
            "name": "achieved",
            "kind": "Measure"
        },
        {
            "displayName": "Category",
            "name": "category",
            "kind": "Grouping"
        }
    ],
    "objects": {
        "gridSettings": {
            "properties": {
                "dotShape": {
                    "type": {
                        "text": true
                    }
                },
                "maxDots": {
                    "type": {
                        "numeric": true
                    }
                },
                "dotGap": {
                    "type": {
                        "numeric": true
                    }
                },
                "showCenterText": {
                    "type": {
                        "bool": true
                    }
                },
                "achievedColor": {
                    "type": {
                        "fill": {
                            "solid": {
                                "color": true
                            }
                        }
                    }
                },
                "emptyColor": {
                    "type": {
                        "fill": {
                            "solid": {
                                "color": true
                            }
                        }
                    }
                },
                "fontFamily": {
                    "type": {
                        "text": true
                    }
                }
            }
        },
        "legendSettings": {
            "properties": {
                "showUnitLegend": {
                    "type": {
                        "bool": true
                    }
                },
                "showCategoryLegend": {
                    "type": {
                        "bool": true
                    }
                }
            }
        }
    },
    "dataViewMappings": [
        {
            "conditions": [
                {
                    "total": {
                        "max": 1
                    },
                    "achieved": {
                        "max": 1
                    },
                    "category": {
                        "max": 1
                    }
                }
            ],
            "categorical": {
                "categories": {
                    "for": {
                        "in": "category"
                    },
                    "dataReductionAlgorithm": {
                        "top": {
                            "count": 20
                        }
                    }
                },
                "values": {
                    "select": [
                        {
                            "bind": {
                                "to": "total"
                            }
                        },
                        {
                            "bind": {
                                "to": "achieved"
                            }
                        }
                    ]
                }
            }
        }
    ],
    "tooltips": {
        "supportedTypes": {
            "default": true,
            "canvas": true
        }
    },
    "supportsLandingPage": true,
    "supportsEmptyDataView": true,
    "privileges": []
}