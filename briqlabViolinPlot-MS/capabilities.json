{
    "dataRoles": [
        {
            "displayName": "Category",
            "name": "category",
            "kind": "Grouping"
        },
        {
            "displayName": "Value",
            "name": "value",
            "kind": "Measure"
        },
        {
            "displayName": "Comparison",
            "name": "comparison",
            "kind": "Grouping"
        }
    ],
    "objects": {
        "distributionSettings": {
            "properties": {
                "kdeBandwidth": {
                    "type": {
                        "text": true
                    }
                },
                "showBoxPlot": {
                    "type": {
                        "bool": true
                    }
                },
                "showOutliers": {
                    "type": {
                        "bool": true
                    }
                },
                "violinWidth": {
                    "type": {
                        "numeric": true
                    }
                },
                "fillOpacity": {
                    "type": {
                        "numeric": true
                    }
                },
                "fontFamily": {
                    "type": {
                        "text": true
                    }
                }
            }
        },
        "statsSettings": {
            "properties": {
                "showRefLine": {
                    "type": {
                        "text": true
                    }
                },
                "refLineColor": {
                    "type": {
                        "fill": {
                            "solid": {
                                "color": true
                            }
                        }
                    }
                }
            }
        },
        "labelSettings": {
            "properties": {
                "showLabels": {
                    "type": {
                        "bool": true
                    }
                },
                "fontSize": {
                    "type": {
                        "numeric": true
                    }
                }
            }
        }
    },
    "dataViewMappings": [
        {
            "conditions": [
                {
                    "category": {
                        "max": 1
                    },
                    "value": {
                        "max": 1
                    },
                    "comparison": {
                        "max": 1
                    }
                }
            ],
            "categorical": {
                "categories": {
                    "select": [
                        {
                            "bind": {
                                "to": "category"
                            }
                        },
                        {
                            "bind": {
                                "to": "comparison"
                            }
                        }
                    ],
                    "dataReductionAlgorithm": {
                        "top": {
                            "count": 5000
                        }
                    }
                },
                "values": {
                    "select": [
                        {
                            "bind": {
                                "to": "value"
                            }
                        }
                    ]
                }
            }
        }
    ],
    "tooltips": {
        "supportedTypes": {
            "default": true,
            "canvas": true
        }
    },
    "supportsLandingPage": true,
    "supportsEmptyDataView": true,
    "privileges": []
}