{
    "dataRoles": [
        {
            "displayName": "Entity",
            "name": "entity",
            "kind": "Grouping"
        },
        {
            "displayName": "Dimension",
            "name": "dimension",
            "kind": "Grouping"
        },
        {
            "displayName": "Value",
            "name": "value",
            "kind": "Measure"
        },
        {
            "displayName": "Benchmark",
            "name": "benchmark",
            "kind": "Measure"
        }
    ],
    "objects": {
        "radarSettings": {
            "properties": {
                "gridRings": {
                    "type": {
                        "numeric": true
                    }
                },
                "maxEntities": {
                    "type": {
                        "numeric": true
                    }
                },
                "fillOpacity": {
                    "type": {
                        "numeric": true
                    }
                },
                "showDots": {
                    "type": {
                        "bool": true
                    }
                },
                "showBenchmark": {
                    "type": {
                        "bool": true
                    }
                },
                "showScoreCards": {
                    "type": {
                        "bool": true
                    }
                }
            }
        },
        "labelSettings": {
            "properties": {
                "axisFontSize": {
                    "type": {
                        "numeric": true
                    }
                },
                "showAxisValues": {
                    "type": {
                        "bool": true
                    }
                },
                "fontFamily": {
                    "type": {
                        "text": true
                    }
                }
            }
        }
    },
    "dataViewMappings": [
        {
            "conditions": [
                {
                    "entity": {
                        "max": 1
                    },
                    "dimension": {
                        "max": 1
                    },
                    "value": {
                        "max": 1
                    },
                    "benchmark": {
                        "max": 1
                    }
                }
            ],
            "categorical": {
                "categories": {
                    "select": [
                        {
                            "bind": {
                                "to": "entity"
                            }
                        },
                        {
                            "bind": {
                                "to": "dimension"
                            }
                        }
                    ],
                    "dataReductionAlgorithm": {
                        "top": {
                            "count": 500
                        }
                    }
                },
                "values": {
                    "select": [
                        {
                            "bind": {
                                "to": "value"
                            }
                        },
                        {
                            "bind": {
                                "to": "benchmark"
                            }
                        }
                    ]
                }
            }
        }
    ],
    "tooltips": {
        "supportedTypes": {
            "default": true,
            "canvas": true
        }
    },
    "supportsLandingPage": true,
    "supportsEmptyDataView": true,
    "privileges": []
}